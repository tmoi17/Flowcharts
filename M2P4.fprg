    </attributes>
    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="lastname" type="String" array="False" size=""/>
            <declare name="numcredithours" type="Integer" array="False" size=""/>
            <declare name="TUITION" type="Integer" array="False" size=""/>
            <declare name="labfee" type="Integer" array="False" size=""/>
            <input variable="lastname"/>
            <input variable="numcredithours"/>
            <assign variable="labfee" expression="100"/>
            <assign variable="TUITION" expression="(numcredithours * 250) + labfee"/>
            <output expression="lastname &amp; &quot;, your total tuition is $&quot; &amp; TUITION" newline="True"/>
        </body>
    </function>
</flowgorithm>
